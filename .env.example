# Copy this file to .env and export it:
#   cp .env.example .env
#   set -a; source .env; set +a

# ------------------------------------------------------------------------------
# Service ports / startup
# ------------------------------------------------------------------------------
HELIX_PORT=8003
FRONTEND_PORT=5173
START_BOT=0
# Autonomous trading daemon (strategy scanning + order management). Off by
# default; only enable once you understand what it will do with your config.
START_DAEMON=0

# ------------------------------------------------------------------------------
# API access controls (optional, recommended if exposed beyond localhost)
# ------------------------------------------------------------------------------
# Required for all /api/* requests when set
HELIX_API_KEY=
# Frontend header injection for browser requests
VITE_HELIX_API_KEY=

# Required for operator-only dangerous endpoints when set
HELIX_OPERATOR_KEY=
VITE_HELIX_OPERATOR_KEY=

# Set to true to refuse startup when HELIX_API_KEY or HELIX_OPERATOR_KEY is unset.
# Default (unset): app boots with a loud warning but auth is bypassed.
# Recommended for any deployment beyond a trusted single-user localhost.
HELIX_AUTH_REQUIRED=false

# Network bind address. Defaults to 127.0.0.1 (localhost only). If you set this
# to 0.0.0.0 or a LAN IP, the API (which can execute code and manage orders)
# becomes network-reachable, so the app REFUSES to start unless HELIX_API_KEY
# is also set. Leave at 127.0.0.1 for the normal single-user setup.
HELIX_BIND_HOST=127.0.0.1

# ------------------------------------------------------------------------------
# Storage paths (optional)
# ------------------------------------------------------------------------------
# Default: ~/.helix
HELIX_HOME=

# Default: ./data
HELIX_DATA_DIR=

# ------------------------------------------------------------------------------
# Encryption (recommended)
# ------------------------------------------------------------------------------
# If unset, a local key file is generated at data/.helix_key.
# For portability and secure deployments, set an explicit Fernet key:
#   python3 - <<'PY'
#   from cryptography.fernet import Fernet
#   print(Fernet.generate_key().decode())
#   PY
HELIX_ENCRYPTION_KEY=

# ------------------------------------------------------------------------------
# Trading safety toggles
# ------------------------------------------------------------------------------
# Execution mode: "paper" (the supported default) or "live" (UNSUPPORTED).
# Live/mainnet trading is disabled by default and entirely at your own risk. The
# in-app/API switch refuses anything but paper, so reaching a real-money order
# requires deliberately setting this to live AND HELIX_ALLOW_MAINNET=1 below AND
# wiring mainnet credentials. There is no accidental path to live.
HELIX_EXECUTION_MODE=paper

# Hard real-funds gate: the exchange layer refuses real-funds (mainnet) orders
# unless this is 1 (default-deny). Leave at 0 unless you fully accept the risk.
HELIX_ALLOW_MAINNET=0

# HyperLiquid credentials (optional). If set, file-based creds are not required.
HELIX_HL_API_SECRET=
HELIX_HL_API_KEY=
HELIX_HL_WALLET_ADDRESS=
HELIX_HL_USE_TESTNET=true

# Set to 1 to read plaintext HyperLiquid settings.json without a .key file.
HELIX_HL_DISABLE_ENCRYPTION=0

# ------------------------------------------------------------------------------
# Agent safety
# ------------------------------------------------------------------------------
# The LLM agent's raw shell tool is DISABLED by default — its mix of subprocess
# execution + tool-calling + web-ingested content is a prompt-injection risk.
# Set to 1 to allow it, entirely at your own risk.
HELIX_ENABLE_SHELL_TOOL=0
# When the shell tool is enabled, also restrict it to a vetted program allowlist.
HELIX_SHELL_STRICT_ALLOWLIST=1

# ------------------------------------------------------------------------------
# Optional integrations
# ------------------------------------------------------------------------------
DISCORD_TOKEN=

# ------------------------------------------------------------------------------
# GitHub webhook auto-update (optional)
# ------------------------------------------------------------------------------
# Required to enable /api/webhooks/github
HELIX_GITHUB_WEBHOOK_SECRET=
# Branch to auto-pull when GitHub push event arrives (default: main)
HELIX_GITHUB_WEBHOOK_BRANCH=main
# Git remote and repository path to update (set to your local checkout)
HELIX_GITHUB_WEBHOOK_REMOTE=origin
HELIX_GITHUB_WEBHOOK_REPO=
# Optional command run after successful pull (example: restart stack service)
# HELIX_GITHUB_WEBHOOK_POST_PULL_CMD=systemctl --user restart helix-stack.service
HELIX_GITHUB_WEBHOOK_POST_PULL_CMD=

# ------------------------------------------------------------------------------
# In-app self-update ("Check for updates" in Settings + startup banner)
# ------------------------------------------------------------------------------
# Which remote/branch the in-app updater fast-forwards to. Defaults below; only
# set these to track a non-default branch. The updater never force-resets: a
# dirty tree, local commits, or being on another branch block the update with a
# message instead. Applying restarts the backend via the start_all supervisor.
HELIX_UPDATE_REMOTE=origin
HELIX_UPDATE_BRANCH=main

# Optional explicit Helix -> API base
HELIX_CLIENT_BASE=http://127.0.0.1:8003
